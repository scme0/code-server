# Copy to .env (gitignored) and fill in your per-person values.

# Workspace mode:
#   mount (default) — bind-mount your existing host repos dir RW into the sandbox.
#                     Fast start, edits live on the host. Set REPOS_DIR below.
#                     PAT can be read-only; you push from the host.
#   clone           — repos are cloned + `reset --hard origin` into an ephemeral
#                     volume on every boot (fully isolated). PAT needs write so the
#                     agent can push branches for you to open PRs from.
WORKSPACE_MODE=mount

# MOUNT mode (default). Two ways to choose what gets mounted RW at /data/workspace:
#
#   REPOS  — RECOMMENDED. A space/newline list of specific repos to mount
#            individually. Only these end up in the workspace → fast (avoids
#            watching your whole dev dir). Names are resolved under REPOS_DIR, or
#            give absolute paths. Example:
#              REPOS="my-service my-lib"
#   REPOS_DIR — base dir for the names above, AND the fallback: if REPOS is empty
#            the WHOLE dir is mounted (slow for a big ~/dev — see README).
#   macOS:  /Users/you/dev      WSL2: /home/you/dev  (inside WSL2 fs, NOT /mnt/c/...)
REPOS=
REPOS_DIR=

# CLONE mode only. Space/newline list of owner/repo slugs cloned (and
# `reset --hard origin`) into the ephemeral workspace each boot. Set here →
# up.sh writes them into the `work-repos` configmap, so you don't edit
# base/configmaps.yaml. Leave empty → the committed default in that file is used.
#   CLONE_REPOS="your-org/your-service your-org/helm-charts"
CLONE_REPOS=

# Shell/dotfiles provisioning:
#   default — ship a sensible minimal .zshrc (no secrets/deps). Good out of the box.
#   chezmoi — `chezmoi apply` from DOTFILES_SRC (RO-mounted local source). Runs with
#             --exclude=scripts,encrypted and CODE_SERVER_SANDBOX=1 set. Gate secret/
#             cluster files in your .chezmoiignore, e.g.:
#               {{ if env "CODE_SERVER_SANDBOX" }}
#               .kube
#               .talos
#               {{ end }}
#   host    — copy your own dotfiles from DOTFILES_SRC (a dir; uses its .zshrc).
#   none    — bare shell.
DOTFILES_MODE=default

# Host DIR mounted read-only at /mnt/dotfiles-src.
#   chezmoi mode: OPTIONAL — auto-detected via `chezmoi source-path` (falls back to
#                 ~/.local/share/chezmoi). Set only to override.
#   host mode:    REQUIRED — the dir holding your dotfiles (uses its .zshrc).
# NOTE: mounting the LOCAL source avoids needing the (work-scoped) PAT to clone a
# private dotfiles repo.
DOTFILES_SRC=

# Your work-notes directory (OPTIONAL). Set → mounted at /mnt/notes and symlinked
# into the workspace (shows in terminal + VS Code). Leave UNSET → notes fully
# ignored (no mount, no folder, no symlink).
#   macOS:  /Users/you/Notes/work
#   WSL2:   /home/you/notes/work     (keep it INSIDE the WSL2 filesystem, NOT /mnt/c/...)
NOTES_DIR=

# Persistent sandbox state dir (optional — defaults to ~/.code-server-work/state).
# Host-mounted at /data so it SURVIVES down.sh: Claude auth + memories + history
# (~/.claude, ~/.claude-home, ~/.claude-work), code-server state, shell home. This
# is a DEDICATED dir — do NOT point it at your real ~/.claude.
STATE_DIR=

# 1Password account to use, as its sign-in address. REQUIRED if `op` is signed in
# to more than one account (e.g. personal + work) — otherwise op picks the wrong
# one and secret refs fail to resolve. Set to your work account.
OP_ACCOUNT=my-team.1password.com

# 1Password reference (op:// path) to YOUR scoped GitHub PAT.
# Make a fine-grained PAT limited to the work repos:
#   mount mode: contents:read + pull_requests:read  (you push from the host)
#   clone mode: contents:read + pull_requests:write + contents:write (agent pushes)
OP_GH_PAT_REF=op://Work/code-server-work/github-pat

# Anthropic auth: run `claude /login` once inside the sandbox terminal (OAuth —
# works with enterprise/subscription accounts; token persists in the state dir).
# No API key here. (api.anthropic.com/claude.ai/platform.claude.com are
# allowlisted; the OAuth token lives in the pod but egress-lock prevents exfil.)

# Extra egress domains to allow, on top of the baked defaults in
# gateway/allowlist.default (github, dockerhub, npm/pypi/go, anthropic, open-vsx,
# stackoverflow, …). Space/newline separated; matches the domain + subdomains.
# Edit + re-run up.sh → the gateway live-reloads in ≤10s, no pod restart.
#   EGRESS_ALLOW="octopus.com mycompany.example.com pkgs.dev"
EGRESS_ALLOW=

# Optional host-port overrides (per instance). Defaults: work = 4444/7681;
# other --name instances derive unique ports automatically. Set only to pin them.
# VSCODE_PORT=
# TTYD_PORT=
