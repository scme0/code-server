# Rendered by up.sh (envsubst) → kind-cluster.yaml. Do not edit the rendered file.
# Single-node kind cluster for the work sandbox.
kind: Cluster
apiVersion: kind.x-k8s.io/v1alpha4
name: code-server-work
nodes:
  - role: control-plane
    # Pin the node image for reproducibility across the team. Adjust the tag to
    # one your installed `kind` version supports (see the kind release notes).
    image: kindest/node:v1.33.1
    # Native host port publishing — baked into the node container at create time,
    # so it survives `docker start` (no kubectl port-forward, no up.sh re-run).
    # Maps host 127.0.0.1:<hostPort> → node <containerPort> (= the Service's
    # nodePort). Bound to 127.0.0.1 only: never exposed to the LAN.
    extraPortMappings:
      - containerPort: 30444      # code-server NodePort
        hostPort: 4444
        listenAddress: "127.0.0.1"
        protocol: TCP
      - containerPort: 30681      # ttyd NodePort
        hostPort: 7681
        listenAddress: "127.0.0.1"
        protocol: TCP
    extraMounts:
      # Persistent sandbox state (/data): Claude auth/memories/history, code-server
      # state, shell home. ALWAYS on; survives down.sh so you keep login + memories.
      - hostPath: ${STATE_DIR}
        containerPath: /mnt/state
      # Notes (OPTIONAL): up.sh injects NOTES_DIR → /mnt/notes below if set; empty
      # if unset (notes then fully ignored — no folder, no symlink). WSL2: keep
      # NOTES_DIR inside the WSL2 fs, NOT /mnt/c.
${NOTES_MOUNT}
      # MOUNT mode only: up.sh injects each repo (REPOS) or whole REPOS_DIR → /mnt/repos.
${REPOS_MOUNT}
      # DOTFILES_MODE=host|chezmoi only: up.sh injects DOTFILES_SRC → /mnt/dotfiles-src.
${DOTFILES_MOUNT}
